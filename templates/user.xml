<templateSet group="user">
  <template name="&lt;con&gt;" value="var_dump(&quot;&quot;);" description="var_dump" toReformat="true" toShortenFQNames="true">
    <context>
      <option name="PHP" value="true" />
    </context>
  </template>
  <template name="clo" value="console.log('$TITLE$', $VALUE$);" description="console.log with title and value" toReformat="true" toShortenFQNames="true">
    <variable name="TITLE" expression="" defaultValue="" alwaysStopAt="true" />
    <variable name="VALUE" expression="" defaultValue="" alwaysStopAt="true" />
    <context>
      <option name="JAVA_SCRIPT" value="true" />
      <option name="TypeScript" value="true" />
      <option name="Vue" value="true" />
      <option name="XML" value="true" />
      <option name="PHP" value="true" />
    </context>
  </template>
  <template name="pf" value="public function $NAME$($PARAMS$)&#10;{&#10;    $END$&#10;}" description="public function (Allman braces)" toReformat="false" toShortenFQNames="true">
    <variable name="NAME" expression="" defaultValue="&quot;&quot;" alwaysStopAt="true" />
    <variable name="PARAMS" expression="" defaultValue="&quot;&quot;" alwaysStopAt="true" />
    <context>
      <option name="PHP" value="true" />
    </context>
  </template>
</templateSet>